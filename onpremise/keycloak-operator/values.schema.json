{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "keycloak-operator values",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "commonLabels": { "$ref": "#/$defs/stringMap" },
    "commonAnnotations": { "$ref": "#/$defs/stringMap" },
    "resourceMetadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "serviceAccount": { "$ref": "#/$defs/metadataBlock" },
        "deployment": { "$ref": "#/$defs/metadataBlock" },
        "service": { "$ref": "#/$defs/metadataBlock" },
        "role": { "$ref": "#/$defs/metadataBlock" },
        "clusterRoles": { "$ref": "#/$defs/metadataBlock" },
        "roleBinding": { "$ref": "#/$defs/metadataBlock" },
        "clusterRoleBindings": { "$ref": "#/$defs/metadataBlock" }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "serverImage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": { "name": { "type": "string" } }
      }
    },
    "replicas": { "type": "integer", "minimum": 0 },
    "resources": { "$ref": "#/$defs/resources" },
    "nodeSelector": { "$ref": "#/$defs/stringMap" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "priorityClassName": { "type": "string" },
    "topologySpreadConstraints": { "type": "array" },
    "podLabels": { "$ref": "#/$defs/stringMap" },
    "podAnnotations": { "$ref": "#/$defs/stringMap" },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "extraEnv": { "type": "array" },
    "watchNamespaces": { "type": "string", "minLength": 1 },
    "probes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "liveness": { "$ref": "#/$defs/probe" },
        "readiness": { "$ref": "#/$defs/probe" },
        "startup": { "$ref": "#/$defs/probe" }
      }
    },
    "volumeMounts": { "type": "array" },
    "volumes": { "type": "array" },
    "deploymentExtra": { "type": "object", "additionalProperties": true },
    "containerExtra": { "type": "object", "additionalProperties": true },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "targetPort": { "type": ["integer", "string"] },
        "name": { "type": "string", "minLength": 1 },
        "annotations": { "$ref": "#/$defs/stringMap" },
        "labels": { "$ref": "#/$defs/stringMap" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string", "minLength": 1 },
        "annotations": { "$ref": "#/$defs/stringMap" },
        "labels": { "$ref": "#/$defs/stringMap" }
      }
    },
    "rbac": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "subjectNamespace": { "type": "string" }
      }
    },
    "crds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "install": { "type": "boolean" },
        "keep": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "stringMap": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "metadataBlock": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "labels": { "$ref": "#/$defs/stringMap" },
        "annotations": { "$ref": "#/$defs/stringMap" }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "limits": { "type": "object" },
        "requests": { "type": "object" },
        "claims": { "type": "array" }
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "initialDelaySeconds": { "type": "integer", "minimum": 0 },
        "periodSeconds": { "type": "integer", "minimum": 1 },
        "failureThreshold": { "type": "integer", "minimum": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "successThreshold": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
