{
  "id": null,
  "uid": "elasticsearch-overview",
  "title": "Elasticsearch",
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "30s",
  "tags": ["elasticsearch", "search", "logging", "exporter"],
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(elasticsearch_cluster_health_status, job)",
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Cluster Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "elasticsearch_cluster_health_status{job=~\"$job\",color=\"green\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "Green", "color": "green" },
                "0": { "text": "Not Green", "color": "red" }
              }
            }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Nodes",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [
        {
          "expr": "elasticsearch_cluster_health_number_of_nodes{job=~\"$job\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Data Nodes",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "elasticsearch_cluster_health_number_of_data_nodes{job=~\"$job\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Shards",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "elasticsearch_cluster_health_active_shards{job=~\"$job\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Unassigned",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "elasticsearch_cluster_health_unassigned_shards{job=~\"$job\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Pending Tasks",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [
        {
          "expr": "elasticsearch_cluster_health_number_of_pending_tasks{job=~\"$job\"}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Storage",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Filesystem",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "elasticsearch_filesystem_data_size_bytes",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "elasticsearch_filesystem_data_available_bytes",
          "legendFormat": "Available",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Index Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "rate(elasticsearch_index_stats_indexing_index_total{job=~\"$job\"}[5m])",
          "legendFormat": "Index/sec",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Operations",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Search",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "targets": [
        {
          "expr": "rate(elasticsearch_index_stats_search_query_total{job=~\"$job\"}[5m])",
          "legendFormat": "Query/sec",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Flush",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "targets": [
        {
          "expr": "rate(elasticsearch_index_stats_flush_total{job=~\"$job\"}[5m])",
          "legendFormat": "Flush/sec",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "JVM",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Heap",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "elasticsearch_jvm_memory_used_bytes{job=~\"$job\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "elasticsearch_jvm_memory_max_bytes{job=~\"$job\"}",
          "legendFormat": "Max",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "GC",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "rate(elasticsearch_jvm_gc_collection_seconds_sum{job=~\"$job\"}[5m])",
          "legendFormat": "{{gc}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  }
}
