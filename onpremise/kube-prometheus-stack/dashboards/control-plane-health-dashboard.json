    {"datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 3}]}}, "overrides": []}, "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1}, "id": 2, "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}, "title": "Leader Changes (1h)", "type": "stat", "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "increase(etcd_server_leader_changes_seen_total[1h])", "refId": "A"}]},

    {"datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 200}, {"color": "red", "value": 350}]}}, "overrides": []}, "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1}, "id": 3, "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}, "title": "apiserver inflight (R/W max)", "type": "stat", "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "max(apiserver_current_inflight_requests)", "refId": "A"}]},

    {"datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "reqps", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.05}, {"color": "red", "value": 0.5}]}}, "overrides": []}, "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1}, "id": 4, "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}, "title": "apiserver 5xx /s", "type": "stat", "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(apiserver_request_total{code=~\"5..\"}[5m]))", "refId": "A"}]},

    {"datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 12}, {"color": "red", "value": 20}]}}, "overrides": []}, "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1}, "id": 5, "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}, "title": "gitlab-runner pods", "type": "stat", "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "count(kube_pod_info{namespace=\"gitlab-runner\"})", "refId": "A"}]},

    {"datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "reqps", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.1}, {"color": "red", "value": 0.3}]}}, "overrides": []}, "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1}, "id": 6, "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}, "title": "Pod create/s (cluster)", "type": "stat", "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(apiserver_request_total{verb=\"POST\",resource=\"pods\"}[5m]))", "refId": "A"}]},

    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5}, "id": 101, "title": "etcd Latency", "type": "row"},

    {"datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6}, "id": 7, "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["max", "mean"]}, "tooltip": {"mode": "multi"}}, "title": "etcd request p99 by operation", "description": "Apiserver→etcd request latency. >1s sustained on get/list/update is a red flag.", "type": "timeseries", "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.99, sum by (le, operation) (rate(etcd_request_duration_seconds_bucket[2m])))", "legendFormat": "{{operation}}", "refId": "A"}]},

    {"datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6}, "id": 8, "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["max"]}, "tooltip": {"mode": "multi"}}, "title": "etcd disk WAL fsync p99 / p99.9", "description": "Disk write latency to etcd WAL. p99 > 25ms or p99.9 > 100ms means disk is the bottleneck.", "type": "timeseries", "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.99, rate(etcd_disk_wal_fsync_duration_seconds_bucket[2m]))", "legendFormat": "p99", "refId": "A"}, {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.999, rate(etcd_disk_wal_fsync_duration_seconds_bucket[2m]))", "legendFormat": "p99.9", "refId": "B"}]},

    {"datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14}, "id": 9, "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["max"]}, "tooltip": {"mode": "multi"}}, "title": "etcd backend commit p99 / p99.9", "description": "BoltDB commit latency. Sustained > 250ms = compaction or storage pressure.", "type": "timeseries", "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.99, rate(etcd_disk_backend_commit_duration_seconds_bucket[2m]))", "legendFormat": "p99", "refId": "A"}, {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.999, rate(etcd_disk_backend_commit_duration_seconds_bucket[2m]))", "legendFormat": "p99.9", "refId": "B"}]},

    {"datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []}, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14}, "id": 10, "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}}, "title": "etcd MVCC DB size", "description": "Cumulative DB size. Approaching --quota-backend-bytes triggers NOSPACE.", "type": "timeseries", "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "etcd_mvcc_db_total_size_in_bytes", "legendFormat": "total", "refId": "A"}, {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "etcd_mvcc_db_total_size_in_use_in_bytes", "legendFormat": "in_use", "refId": "B"}]},

    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 22}, "id": 102, "title": "kube-apiserver Latency", "type": "row"},

    {"datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 23}, "id": 11, "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["max"]}, "tooltip": {"mode": "multi"}}, "title": "apiserver pods request p99 by verb/scope", "description": "Direct symptom — p99 > 1s on pods GET/LIST is what users feel as `kubectl get pods` lag.", "type": "timeseries", "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.99, sum by (le, verb, scope) (rate(apiserver_request_duration_seconds_bucket{resource=\"pods\",verb=~\"GET|LIST\"}[2m])))", "legendFormat": "{{verb}} {{scope}}", "refId": "A"}]},

    {"datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 23}, "id": 12, "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["max"]}, "tooltip": {"mode": "multi"}}, "title": "apiserver request p99 by resource (top 5)", "description": "Top 5 resources by p99 latency, mutating verbs only.", "type": "timeseries", "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "topk(5, histogram_quantile(0.99, sum by (le, resource, verb) (rate(apiserver_request_duration_seconds_bucket{verb=~\"POST|PUT|PATCH|DELETE\",resource!=\"\"}[2m]))))", "legendFormat": "{{verb}} {{resource}}", "refId": "A"}]},

    {"datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 31}, "id": 13, "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["max"]}, "tooltip": {"mode": "multi"}}, "title": "apiserver error rate by code", "description": "Spikes on 500/503/429 indicate apiserver overload or downstream (etcd) failure.", "type": "timeseries", "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (code) (rate(apiserver_request_total{code=~\"5..|429\"}[2m]))", "legendFormat": "{{code}}", "refId": "A"}]},

    {"datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 31}, "id": 14, "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "title": "apiserver inflight requests", "description": "Read vs mutating concurrent requests. Hitting --max-(mutating-)requests-inflight = saturation.", "type": "timeseries", "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "apiserver_current_inflight_requests", "legendFormat": "{{request_kind}}", "refId": "A"}]},

    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 39}, "id": 103, "title": "CI Correlation (GitLab Runner)", "type": "row"},

    {"datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 40}, "id": 15, "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["max"]}, "tooltip": {"mode": "multi"}}, "title": "Pod count by namespace (top churning)", "description": "CI runner pod churn. gitlab-runner spikes correlate with control-plane latency peaks.", "type": "timeseries", "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "topk(8, count by (namespace) (kube_pod_info))", "legendFormat": "{{namespace}}", "refId": "A"}]},

    {"datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 40}, "id": 16, "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["max"]}, "tooltip": {"mode": "multi"}}, "title": "Pod create/delete rate by namespace", "description": "Per-namespace pod write traffic. gitlab-runner is the usual culprit during CI bursts.", "type": "timeseries", "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (namespace) (rate(apiserver_request_total{verb=\"POST\",resource=\"pods\",code=\"201\"}[2m]))", "legendFormat": "create {{namespace}}", "refId": "A"}, {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (namespace) (rate(apiserver_request_total{verb=\"DELETE\",resource=\"pods\"}[2m]))", "legendFormat": "delete {{namespace}}", "refId": "B"}]},

    {"datasource": {"type": "prometheus", "uid": "prometheus"}, "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}, "gridPos": {"h": 8, "w": 24, "x": 0, "y": 48}, "id": 17, "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["max"]}, "tooltip": {"mode": "multi"}}, "title": "Top apiserver write callers (verb,resource)", "description": "Identify which controllers/clients dominate write traffic during incidents.", "type": "timeseries", "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "topk(10, sum by (verb, resource) (rate(apiserver_request_total{verb=~\"POST|PUT|PATCH|DELETE\"}[2m])))", "legendFormat": "{{verb}} {{resource}}", "refId": "A"}]}
  ]
}
