{
  "id": null,
  "uid": "nginx-gateway-fabric",
  "title": "NGINX Gateway Fabric",
  "description": "NGINX Gateway Fabric (NGF) — control-plane (reconcile loop, work-queue, event batching, resources) + data-plane (request rate, connections, CPU/memory, network throughput from nginx-agent OTEL export on port 9113). No latency histograms or status-code labels (not exposed by NGF 2.x).",
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "30s",
  "tags": ["nginx-gateway", "nginx-gateway-fabric", "ngf", "gateway-api", "networking", "kubernetes"],
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(controller_runtime_reconcile_total, namespace)",
        "regex": "/nginx-gateway.*/",
        "current": { "selected": true, "text": "nginx-gateway", "value": "nginx-gateway" },
        "multi": false,
        "includeAll": false
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up{namespace=\"$namespace\"}, pod)",
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "controller",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(controller_runtime_reconcile_total{namespace=\"$namespace\"}, controller)",
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Controllers Up",
      "description": "NGF controller Pods exposing /metrics (up=1). Filtered by container=\"nginx-gateway\" so data-plane Pods (container=\"nginx\") don't inflate the count.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(up{namespace=\"$namespace\", container=\"nginx-gateway\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Reconcile Errors / sec (5m)",
      "description": "Sum of controller_runtime_reconcile_errors_total rate across selected controllers.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(controller_runtime_reconcile_errors_total{namespace=\"$namespace\", controller=~\"$controller\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Goroutines",
      "description": "Total Go goroutines across NGF pods; sudden jumps may indicate a leak.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [
        {
          "expr": "sum(go_goroutines{namespace=\"$namespace\", pod=~\"$pod\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Memory RSS",
      "description": "Sum of process_resident_memory_bytes across NGF pods.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "targets": [
        {
          "expr": "sum(process_resident_memory_bytes{namespace=\"$namespace\", pod=~\"$pod\"})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Reconciliation",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Reconcile Rate by Controller",
      "description": "rate(controller_runtime_reconcile_total[5m]) split by controller + result.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "targets": [
        {
          "expr": "sum by (controller, result) (rate(controller_runtime_reconcile_total{namespace=\"$namespace\", controller=~\"$controller\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{controller}} / {{result}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Reconcile Latency",
      "description": "p50 / p95 / p99 reconcile duration per controller.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, controller) (rate(controller_runtime_reconcile_time_seconds_bucket{namespace=\"$namespace\", controller=~\"$controller\"}[5m])))",
          "refId": "A",
          "legendFormat": "p50 {{controller}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, controller) (rate(controller_runtime_reconcile_time_seconds_bucket{namespace=\"$namespace\", controller=~\"$controller\"}[5m])))",
          "refId": "B",
          "legendFormat": "p95 {{controller}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, controller) (rate(controller_runtime_reconcile_time_seconds_bucket{namespace=\"$namespace\", controller=~\"$controller\"}[5m])))",
          "refId": "C",
          "legendFormat": "p99 {{controller}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Work Queue & Events",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Work Queue Depth",
      "description": "workqueue_depth by controller-runtime queue name. Persistently >0 = backlog.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "sum by (name) (workqueue_depth{namespace=\"$namespace\"})",
          "refId": "A",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "NGF Event Batch p95 Latency",
      "description": "nginx_gateway_fabric_event_batch_processing_milliseconds p95 per pod. Latency spikes indicate slow processing of K8s watch events (Gateway/HTTPRoute/EndpointSlice).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, pod) (rate(nginx_gateway_fabric_event_batch_processing_milliseconds_bucket{namespace=\"$namespace\", pod=~\"$pod\"}[5m])))",
          "refId": "A",
          "legendFormat": "p95 {{pod}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Resources",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Control-Plane CPU Usage per Pod",
      "description": "container_cpu_usage_seconds_total rate for NGF control-plane Pod(s) (container=\"nginx-gateway\"). Data-plane CPU is shown in the Data Plane row via the nginx-agent's system_cpu_utilization_ratio.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"$namespace\", pod=~\"$pod\", container=\"nginx-gateway\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Control-Plane Memory Working Set per Pod",
      "description": "container_memory_working_set_bytes for NGF control-plane Pod(s) (container=\"nginx-gateway\"). Data-plane memory is shown in the Data Plane row via the nginx-agent's system_memory_usage_bytes.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"$namespace\", pod=~\"$pod\", container=\"nginx-gateway\"})",
          "refId": "A",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Data Plane",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "HTTP Request Rate per Pod",
      "description": "rate(nginx_http_requests_total[5m]) per data-plane Pod. NGF 2.x exposes request COUNT only — no status-code (2xx/4xx/5xx) or path breakdown, and no latency histogram.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "sum by (pod) (rate(nginx_http_requests_total{namespace=\"$namespace\", pod=~\"$pod\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Active Connections by State",
      "description": "nginx_http_connection_count_connections (gauge) grouped by nginx_connections_outcome = ACTIVE
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "sum by (nginx_connections_outcome) (nginx_http_connection_count_connections{namespace=\"$namespace\", pod=~\"$pod\"})",
          "refId": "A",
          "legendFormat": "{{nginx_connections_outcome}}"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Connection Accept / Handle Rate",
      "description": "rate(nginx_http_connections_total[5m]) by outcome. ACCEPTED > HANDLED means NGINX dropped connections (resource exhaustion, worker_connections limit).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "fieldConfig": { "defaults": { "unit": "cps" } },
      "targets": [
        {
          "expr": "sum by (nginx_connections_outcome) (rate(nginx_http_connections_total{namespace=\"$namespace\", pod=~\"$pod\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{nginx_connections_outcome}}"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Data-Plane CPU Utilization per Pod",
      "description": "system_cpu_utilization_ratio reported by the nginx-agent inside each data-plane Pod (summed across state=user|system). 1.0 = one full logical CPU.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "expr": "sum by (pod) (system_cpu_utilization_ratio{namespace=\"$namespace\", pod=~\"$pod\"})",
          "refId": "A",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Data-Plane Memory Used per Pod",
      "description": "system_memory_usage_bytes{state=\"used\"} reported by nginx-agent inside each data-plane Pod (OS-visible used memory, not container working-set).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 49 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "sum by (pod) (system_memory_usage_bytes{namespace=\"$namespace\", pod=~\"$pod\", state=\"used\"})",
          "refId": "A",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Data-Plane Network Throughput per Pod (eth0)",
      "description": "rate(system_network_io_bytes_total{device=\"eth0\"}[5m]) split by direction. receive / transmit in bytes per second.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 49 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        {
          "expr": "sum by (pod, direction) (rate(system_network_io_bytes_total{namespace=\"$namespace\", pod=~\"$pod\", device=\"eth0\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{pod}} / {{direction}}"
        }
      ]
    }
  ]
}
